                      "parameters":  {
                                         "jsCode":  "const importantKeywords = [\n  \"urgent\",\"asap\",\"action required\",\"deadline\",\"payment due\",\"incident\",\"outage\",\"security\",\"failed\"\n];\n\nconst normalized = items.map(({ json }) =\u003e {\n  const subject = (json.subject || \u0027\u0027).toLowerCase();\n  const text = (json.textPlain || json.textHtml || \u0027\u0027).toLowerCase();\n  const matched = importantKeywords.filter(k =\u003e subject.includes(k) || text.includes(k));\n  return {\n    ...json,\n    importanceScore: matched.length,\n    matchedKeywords: matched,\n    isImportant: matched.length \u003e 0,\n  };\n});\n\nconst important = normalized.filter(i =\u003e i.isImportant);\nconst lines = important.slice(0, 25).map((m, idx) =\u003e {\n  const fromPart = m.from ? ` | from ${m.from}` : \u0027\u0027;\n  const datePart = m.date ? ` | ${m.date}` : \u0027\u0027;\n  return `${idx + 1}. ${m.subject || \u0027(no subject)\u0027}${fromPart}${datePart}`;\n});\n\nreturn [\n  {\n    json: {\n      scannedCount: normalized.length,\n      importantCount: important.length,\n      summary: lines.length ? lines.join(\u0027\\n\u0027) : \u0027No important emails found in this run.\u0027,\n      generatedAt: new Date().toISOString(),\n    },\n  },\n];",
                                         "mode":  "runOnceForAllItems"
                                     },
